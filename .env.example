# Supabase Data API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxx
# Server-only -- NEVER prefix with NEXT_PUBLIC_, never expose to the browser
SUPABASE_SECRET_KEY=sb_secret_xxxxx

# Session Mode (port 5432) -- used ONLY by drizzle-kit (migrations/generate/push)
DATABASE_URL=postgresql://postgres.xxxxx:[PASSWORD]@aws-0-xx.pooler.supabase.com:5432/postgres

# Transaction Mode (port 6543) -- used by the app's runtime Drizzle client (src/db/index.ts)
DATABASE_URL_RUNTIME=postgresql://postgres.xxxxx:[PASSWORD]@aws-0-xx.pooler.supabase.com:6543/postgres
